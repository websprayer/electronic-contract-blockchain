\RequirePackage[round,numbers]{natbib}
% \bibliographystyle{IEEEtran} % Provides for the format of IEEE references
\bibliographystyle{vancouver} % the Vancouver referencing style

\RequirePackage{abstract}
\setlength{\absleftindent}{0pt}
\setlength{\absrightindent}{0pt}

\RequirePackage{fancyhdr}

\renewcommand{\headrulewidth}{0pt}
\pagestyle{fancy}
\fancyhf{}           % Clear all header and footer fields
\fancyfoot[R]{\thepage} % Place page number on the bottom-right

\setlength{\parindent}{0pt} % Set paragraph indentation to 0
\setlength{\parskip}{6pt} % Set paragraph spacing to 6 pt

\RequirePackage[subfigure]{tocloft} % The template uses the subfigure library. Add this option to prevent potential conflicts
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
% Sets subsection to appear in bold in the directory
\renewcommand{\cftsubsecfont}{\bfseries}
% It is also desired that page numbers of subsections in the catalog be displayed in bold
\renewcommand{\cftsubsecpagefont}{\bfseries}

\renewcommand{\cfttoctitlefont}{\hfill\Large\bfseries}
\renewcommand{\cftaftertoctitle}{\hfill}
\renewcommand{\contentsname}{Table of Contents}
